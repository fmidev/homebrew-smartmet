# Build & run gis tests on macOS

LIB_DIR        := ..
GIS_DIR        := ..
MACGYVER_DIR   := ../../smartmet-library-macgyver
NEWBASE_DIR    := ../../smartmet-library-newbase

BOOST_PREFIX   := $(shell brew --prefix boost)
FMT_PREFIX     := $(shell brew --prefix fmt)
GDAL_PREFIX    := $(shell brew --prefix gdal)
GEOS_PREFIX    := $(shell brew --prefix geos)
PROJ_PREFIX    := $(shell brew --prefix proj)
SQLITE_PREFIX  := $(shell brew --prefix sqlite)
DC_PREFIX      := $(shell brew --prefix double-conversion)
DATE_PREFIX    := $(shell brew --prefix howard-hinnant-date)
GTEST_PREFIX   := $(shell brew --prefix googletest)

CXX      ?= clang++
CXXFLAGS ?= -std=c++17 -O0 -g -Wall -Wno-unused-parameter -Wno-deprecated-declarations -Wno-write-strings
DEFINES   = -DUNIX -DUSE_UNSTABLE_GEOS_CPP_API

REGR_DIR       := ../../smartmet-library-regression

INCLUDES := -I$(GIS_DIR)/gis -I$(GIS_DIR) -I$(MACGYVER_DIR) -I$(NEWBASE_DIR) -I$(REGR_DIR) \
            -I$(BOOST_PREFIX)/include \
            -I$(FMT_PREFIX)/include \
            -I$(GDAL_PREFIX)/include \
            -I$(GEOS_PREFIX)/include \
            -I$(PROJ_PREFIX)/include \
            -I$(SQLITE_PREFIX)/include \
            -I$(DC_PREFIX)/include \
            -I$(DATE_PREFIX)/include \
            -I$(GTEST_PREFIX)/include

LIBDIRS  := -L$(LIB_DIR) -L$(MACGYVER_DIR) \
            -L$(BOOST_PREFIX)/lib \
            -L$(FMT_PREFIX)/lib \
            -L$(GDAL_PREFIX)/lib \
            -L$(GEOS_PREFIX)/lib \
            -L$(PROJ_PREFIX)/lib \
            -L$(SQLITE_PREFIX)/lib \
            -L$(DC_PREFIX)/lib \
            -L$(DATE_PREFIX)/lib \
            -L$(GTEST_PREFIX)/lib

RPATH := -Wl,-rpath,$(realpath $(LIB_DIR)) -Wl,-rpath,$(realpath $(MACGYVER_DIR))

LIBS := -lsmartmet-gis -lsmartmet-macgyver \
        -lboost_thread -lboost_iostreams -lboost_regex -lboost_chrono \
        -lfmt -lgdal -lgeos -lgeos_c -lproj -lsqlite3 \
        -ldouble-conversion -ldate-tz -liconv -lpthread \
        -lgtest -lgtest_main

# Skip EPSGInfoTest (depends on EPSGInfo.cpp which we excluded — needs sqlite3pp)
SKIP_TESTS := EPSGInfoTest

ALL_CPP   := $(wildcard *Test.cpp) ShapeTester.cpp
ALL_TESTS := $(patsubst %.cpp,%,$(ALL_CPP))
TESTS     := $(filter-out $(SKIP_TESTS),$(ALL_TESTS))

.PHONY: all test clean

all: $(TESTS)

obj/%.o: %.cpp
	@mkdir -p obj
	$(CXX) $(CXXFLAGS) $(DEFINES) $(INCLUDES) -MMD -MP -c $< -o $@

$(TESTS): %: obj/%.o
	$(CXX) $(CXXFLAGS) $(LIBDIRS) $(RPATH) -o $@ $< $(LIBS)

test: $(TESTS)
	@echo "=== Running $(words $(TESTS)) gis tests ==="
	@pass=0; fail=0; failed=""; \
	for t in $(filter-out ShapeTester,$(TESTS)); do \
	  if ./$$t > /dev/null 2>&1; then pass=$$((pass+1)); \
	  else fail=$$((fail+1)); failed="$$failed $$t"; fi; \
	done; \
	if [ -x ./ShapeTester ]; then \
	  for f in tests/*.txt; do \
	    if ./ShapeTester $$f > /dev/null 2>&1; then pass=$$((pass+1)); \
	    else fail=$$((fail+1)); failed="$$failed ShapeTester($$f)"; fi; \
	  done; \
	fi; \
	echo "PASS: $$pass  FAIL: $$fail"; \
	if [ $$fail -gt 0 ]; then echo "Failed:$$failed"; fi

clean:
	rm -rf obj $(ALL_TESTS)

-include $(wildcard obj/*.d)
