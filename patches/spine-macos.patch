+        constexpr int kMaxFrames = 128;
+        void* frames[kMaxFrames];
+        const int n = ::backtrace(frames, kMaxFrames);
+        char** symbols = ::backtrace_symbols(frames, n);
+        // Skip frame 0 (this method) to match the libbacktrace path.
+        for (int i = 1; i < n; ++i)
+        {
+            const std::size_t level = ++Backtrace::data.level;
+            Backtrace::data.out << "[" << fmt::format("{:04}", level) << "]:\n"
