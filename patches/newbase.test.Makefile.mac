# Build & run newbase tests on macOS

LIB_DIR        := ..
NEWBASE_DIR    := ..
MACGYVER_DIR   := ../../smartmet-library-macgyver
GIS_DIR        := ../../smartmet-library-gis
REGR_DIR       := ../../smartmet-library-regression

BOOST_PREFIX   := $(shell brew --prefix boost)
FMT_PREFIX     := $(shell brew --prefix fmt)
GDAL_PREFIX    := $(shell brew --prefix gdal)
DC_PREFIX      := $(shell brew --prefix double-conversion)
DATE_PREFIX    := $(shell brew --prefix howard-hinnant-date)
BZIP2_PREFIX   := $(shell brew --prefix bzip2)

CXX      ?= clang++
CXXFLAGS ?= -std=c++17 -O0 -g -Wall -Wno-unused-parameter -Wno-deprecated-declarations
DEFINES   = -DUNIX

INCLUDES := -I$(NEWBASE_DIR)/newbase -I$(NEWBASE_DIR) -I$(MACGYVER_DIR) -I$(GIS_DIR) -I$(REGR_DIR) \
            -I$(BOOST_PREFIX)/include \
            -I$(FMT_PREFIX)/include \
            -I$(GDAL_PREFIX)/include \
            -I$(DC_PREFIX)/include \
            -I$(DATE_PREFIX)/include \
            -I$(BZIP2_PREFIX)/include

LIBDIRS  := -L$(LIB_DIR) -L$(MACGYVER_DIR) -L$(GIS_DIR) \
            -L$(BOOST_PREFIX)/lib \
            -L$(FMT_PREFIX)/lib \
            -L$(GDAL_PREFIX)/lib \
            -L$(DC_PREFIX)/lib \
            -L$(DATE_PREFIX)/lib \
            -L$(BZIP2_PREFIX)/lib

RPATH := -Wl,-rpath,$(realpath $(LIB_DIR)) \
         -Wl,-rpath,$(realpath $(MACGYVER_DIR)) \
         -Wl,-rpath,$(realpath $(GIS_DIR))

LIBS := -lsmartmet-newbase -lsmartmet-gis -lsmartmet-macgyver \
        -lboost_iostreams -lboost_thread -lboost_chrono \
        -lboost_regex -lboost_serialization -lboost_filesystem \
        -lfmt -lgdal -ldouble-conversion -ldate-tz \
        -lz -lbz2 -liconv -lpthread

ALL_TESTS := $(patsubst %.cpp,%,$(wildcard *Test.cpp))
TESTS     := $(ALL_TESTS)

.PHONY: all test clean

all: $(TESTS)

obj/%.o: %.cpp
	@mkdir -p obj
	$(CXX) $(CXXFLAGS) $(DEFINES) $(INCLUDES) -MMD -MP -c $< -o $@

$(TESTS): %: obj/%.o
	$(CXX) $(CXXFLAGS) $(LIBDIRS) $(RPATH) -o $@ $< $(LIBS)

test: $(TESTS)
	@echo "=== Running $(words $(TESTS)) newbase tests ==="
	@pass=0; fail=0; failed=""; \
	for t in $(TESTS); do \
	  if ./$$t > /dev/null 2>&1; then pass=$$((pass+1)); \
	  else fail=$$((fail+1)); failed="$$failed $$t"; fi; \
	done; \
	echo "PASS: $$pass  FAIL: $$fail"; \
	if [ $$fail -gt 0 ]; then echo "Failed:$$failed"; fi

clean:
	rm -rf obj $(ALL_TESTS)

-include $(wildcard obj/*.d)
