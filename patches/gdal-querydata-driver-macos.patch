+// GDAL 3.13 changed the CreateCopyCallback signature's papszOptions parameter
+// from `char**` to `CSLConstList` (`const char *const *`). Match whichever
+// GDAL we're built against so the function pointer assignment in QDDriver
+// type-checks. The function body reads but does not mutate the list.
+#if defined(GDAL_VERSION_NUM) && (GDAL_VERSION_NUM >= GDAL_COMPUTE_VERSION(3, 13, 0))
+using QDCreateCopyOptions = CSLConstList;
+#else
+using QDCreateCopyOptions = char**;
+#endif
