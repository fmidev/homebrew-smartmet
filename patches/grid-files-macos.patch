diff --git a/src/common/GeneralFunctions.h b/src/common/GeneralFunctions.h
index 0d80a97..255e7be 100644
--- a/src/common/GeneralFunctions.h
+++ b/src/common/GeneralFunctions.h
@@ -117,6 +117,19 @@ std::string toString(std::uint8_t value);
 std::string toString(std::uint16_t value);
 std::string toString(std::uint32_t value);
 std::string toString(std::uint64_t value);
+#ifdef __APPLE__
+// macOS arm64: size_t = unsigned long, ssize_t = long, neither of which
+// equals any std::{u,}intN_t exactly. Add explicit overloads so existing
+// call sites that pass size_t / long / unsigned long are unambiguous.
+inline std::string toString(long value)
+{
+  return toString(static_cast<std::int64_t>(value));
+}
+inline std::string toString(unsigned long value)
+{
+  return toString(static_cast<std::uint64_t>(value));
+}
+#endif
 std::string toString(const std::string& value);
 std::string toString(float value);
 std::string toString(double value);
@@ -385,6 +398,10 @@ inline int time_compare(time_t v1, time_t v2)
 
 
 
+// macOS provides htonll() / ntohll() as macros in <sys/_endian.h> via
+// <arpa/inet.h>; defining our own versions on top would collide. The system
+// versions have identical semantics, so we just defer to them.
+#ifndef __APPLE__
 inline Int64 htonll(Int64 value)
 {
   static const int num = 42;
@@ -407,5 +424,6 @@ inline Int64 ntohll(Int64 value)
 
   return value;
 }
+#endif  // !__APPLE__
 
 }
