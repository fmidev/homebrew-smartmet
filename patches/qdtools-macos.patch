+// Compile-time override of the default tz data dir (set by build system for
+// non-FHS installs, e.g. Homebrew). Env vars (FMI_TIMEZONES_*) still win
+// at runtime.
+#ifndef FMI_TIMEZONES_DEFAULT_DIR
+#define FMI_TIMEZONES_DEFAULT_DIR "/usr/share/smartmet/timezones"
+#endif
+
+namespace
+{
+// Resolve the default qdpoint::tzfile path. Precedence:
+//   FMI_TIMEZONES_COORDINATES (env) > FMI_TIMEZONES_DIR (env) > compile-time default.
+std::string default_tzfile()
+{
+  if (const char* p = std::getenv("FMI_TIMEZONES_COORDINATES")) return p;
+  if (const char* d = std::getenv("FMI_TIMEZONES_DIR")) return std::string(d) + "/timezone.shz";
+  return FMI_TIMEZONES_DEFAULT_DIR "/timezone.shz";
+}
+}
